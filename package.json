{
  "name": "neuviii-discord.js-self",
  "version": "1.0.0",
  "description": "An optimized and updated discord.js fork for creating selfbots",
  "main": "./src/index.js",
  "types": "./typings/index.d.ts",
  "type": "commonjs",
  "scripts": {
    "all": "npm run build && npm publish",
    "test": "npm run lint:all && npm run test:typescript",
    "fix:all": "npm run lint:fix && npm run format",
    "test:typescript": "tsc --noEmit && tsd",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/**/*.js typings/**/*.ts",
    "lint:all": "npm run lint",
    "docs": "docgen --source src --custom docs/index.yml --output docs/main.json",
    "docs:test": "docgen --source src --custom docs/index.yml",
    "build": "npm run lint:fix && npm run format"
  },
  "files": [
    "src",
    "typings"
  ],
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neuviii/neuviii-discord.js-self.git"
  },
  "keywords": [
    "discord.js",
    "discord.js v13",
    "selfbot",
    "selfbot v13",
    "djs",
    "api",
    "bot",
    "node",
    "discord",
    "client",
    "discordapp",
    "neuviii"
  ],
  "author": "neuviii",
  "license": "GNU General Public License v3.0",
  "bugs": {
    "url": "https://github.com/neuviii/neuviii-discord.js-self/issues"
  },
  "homepage": "https://github.com/neuviii/neuviii-discord.js-self#readme",
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@discordjs/collection": "^2.1.1",
    "@sapphire/async-queue": "^1.5.5",
    "@sapphire/shapeshift": "^4.0.0",
    "discord-api-types": "^0.38.49",
    "fetch-cookie": "^3.2.0",
    "find-process": "^2.1.1",
    "otplib": "^13.4.1",
    "prism-media": "^1.3.5",
    "qrcode": "^1.5.4",
    "tough-cookie": "^6.0.1",
    "tree-kill": "^1.2.2",
    "undici": "^8.5.0",
    "werift-rtp": "^0.8.8",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20.18"
  },
  "devDependencies": {
    "@discordjs/docgen": "^0.11.1",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.0.0",
    "tsd": "^0.32.0",
    "typescript": "^5.5.4"
  }
}
